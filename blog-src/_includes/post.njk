---
layout: base.njk
---
<article class="post-body">
  <div class="post-meta-head">
    <a href="/blog/" class="back-link">← Writing</a>
    <span class="date">{{ page.date | shortDate }}</span>
    <span class="date">· {{ read }}</span>
    <span class="topic-tag">{{ topic }}</span>
  </div>

  <h1 class="hero">{{ title }}</h1>
  <p class="lede">{{ excerpt }}</p>

  <div class="prose">
    {{ content | safe }}
  </div>
</article>
